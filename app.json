{
  "expo": {
    "name": "Cellar",
    "slug": "wine-cellar-native",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#f8f4ec"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.adamskcohen.winecellar",
      "infoPlist": {
        "NSCameraUsageDescription": "Cellar uses the camera to capture wine labels.",
        "NSPhotoLibraryUsageDescription": "Cellar imports label photos from your camera roll.",
        "NSPhotoLibraryAddUsageDescription": "Cellar can export backup files for sharing."
      }
    },
    "android": {
      "package": "com.adamskcohen.winecellar",
      "permissions": ["CAMERA", "READ_MEDIA_IMAGES"],
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#3a0c18"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-image-picker",
      "expo-camera"
    ]
  }
}
